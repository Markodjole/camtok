{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "SUPABASE_SERVICE_ROLE_KEY",
    "NEXT_PUBLIC_SUPABASE_URL",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY",
    "SUPABASE_DB_URL",
    "LLM_PROVIDER",
    "LLM_API_KEY",
    "LLM_MODEL",
    "LLM_MODEL_ANALYSIS",
    "LLM_MODEL_VISION",
    "LLM_MODEL_TEMPORAL",
    "LLM_MODEL_IMAGE_PATTERNS",
    "LLM_MODEL_IMAGE_ANALYSIS",
    "LLM_MODEL_SCENE_PLANNER",
    "LLM_MODEL_CONTINUATION",
    "LLM_MODEL_PLAUSIBILITY",
    "LLM_MODEL_USER_PREDICTIONS",
    "LLM_MODEL_SETTLEMENT",
    "LLM_MODEL_PREDICTION_ODDS",
    "FAL_KEY",
    "LLM_MODEL_CHARACTER_CLIP_SUGGEST",
    "LIVE_STREAM_SECRET",
    "GOOGLE_MAPS_API_KEY",
    "NEXT_PUBLIC_TURN_URL",
    "NEXT_PUBLIC_TURN_USERNAME",
    "NEXT_PUBLIC_TURN_CREDENTIAL",
    "NEXT_PUBLIC_ICE_RELAY_ONLY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"]
    }
  }
}

{
  "name": "bettok",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "build:vercel-web": "pnpm --filter='...@bettok/web' run build",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:migrate": "supabase db push",
    "db:migrate:local": "supabase migration up --local",
    "db:reset": "supabase db reset",
    "db:seed": "tsx supabase/seed/index.ts",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "camtok:dev": "bash scripts/dev.sh",
    "vercel:env:push": "bash scripts/vercel-env-push.sh",
    "format": "prettier --write \"**/*.{ts,tsx,md,json}\""
  },
  
  "devDependencies": {
    "prettier": "^3.2.0",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  }
}

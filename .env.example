# --- Local dev (Supabase CLI: supabase start) ---
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54331
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<from: supabase status>
# SUPABASE_SERVICE_ROLE_KEY=<from: supabase status>
# SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54332/postgres

# --- Production (Vercel env vars – from Supabase dashboard) ---
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Google Maps / Routes — slow lane only (map line + bet ETAs)
# Fast polls (active-round, tick triggers) use OSRM — never Google.
# Production defaults to OFF until GOOGLE_ROUTES_ENABLED=1
# GOOGLE_ROUTES_ENABLED=1
# GOOGLE_ROUTES_MAX_PER_MIN=20
# GOOGLE_ROUTES_MAX_PER_DAY=800
# GOOGLE_ROUTE_CACHE_TTL_SEC=300
# GOOGLE_MAPS_API_KEY=
#
# Other Google Maps APIs (geocode, places, geo-context)
# GOOGLE_MAPS_APIS_DISABLED=0
# GOOGLE_GEOCODE_MAX_PER_MIN=30
# GOOGLE_GEOCODE_MAX_PER_DAY=1500
# GOOGLE_PLACES_AUTOCOMPLETE_MAX_PER_MIN=40
# GOOGLE_PLACES_DETAILS_MAX_PER_MIN=25
# GOOGLE_PLACES_NEARBY_MAX_PER_MIN=15
# GOOGLE_GEO_CONTEXT_MAX_PER_MIN=6
#
# OSRM (public demo server — still cap to avoid abuse)
# OSRM_MAX_PER_MIN=120
# OSRM_MAX_PER_DAY=15000
#
# Usage report: GET /api/admin/api-usage with Bearer USAGE_REPORT_SECRET
# USAGE_REPORT_SECRET=
#
# MEDIA_PROVIDER=mock
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
# NEXT_PUBLIC_MAPTILER_KEY=
#
# fal.ai (server-side only)
# FAL_KEY=
# FAL_MAX_PER_MIN=8
# FAL_MAX_PER_DAY=200

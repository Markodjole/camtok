# --- Local dev (Supabase CLI: supabase start) ---
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54331
# NEXT_PUBLIC_SUPABASE_ANON_KEY=<from: supabase status>
# SUPABASE_SERVICE_ROLE_KEY=<from: supabase status>
# SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54332/postgres

# --- Production (Vercel env vars – from Supabase dashboard) ---
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Google Maps / Routes — slow lane only (map line + bet ETAs)
# Fast polls (active-round, tick triggers) use OSRM — never Google.
# Production defaults to OFF until GOOGLE_ROUTES_ENABLED=1
# GOOGLE_ROUTES_ENABLED=1
# GOOGLE_ROUTES_MAX_PER_MIN=20
# GOOGLE_ROUTE_CACHE_TTL_SEC=300
# GOOGLE_MAPS_API_KEY=
# MEDIA_PROVIDER=mock
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
#
